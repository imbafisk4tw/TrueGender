    "articles": {
      "description": "Gegenderte Artikel und Pronomen",
      "enabled": true,
      "rules": [
        {
          "id": "der-die-star",
          "description": "der*die / der:die → der/die",
          "example": "der:die",
          "pattern": "\\bder[*:_]die\\b",
          "replacement": { "b": "der oder die", "m": "der", "w": "die", "n": "die/der" },
          "flags": "gi"
        },
        {
          "id": "die-der-star",
          "description": "die*der → der/die",
          "example": "die:der",
          "pattern": "\\bdie[*:_]der\\b",
          "replacement": { "b": "der oder die", "m": "der", "w": "die", "n": "die/der" },
          "flags": "gi"
        },
        {
          "id": "ein-e-star",
          "description": "ein*e / ein:e → ein/eine",
          "example": "ein:e",
          "pattern": "\\bein[*:_]e\\b",
          "replacement": { "b": "ein oder eine", "m": "ein", "w": "eine", "n": "eine" },
          "flags": "gi"
        },
        {
          "id": "jede-r-star",
          "description": "jede*r / jede:r → jeder/jede",
          "example": "jede:r",
          "pattern": "\\bjede[*:_]r\\b",
          "replacement": { "b": "jeder und jede", "m": "jeder", "w": "jede", "n": "alle" },
          "flags": "gi"
        },
        {
          "id": "jeder-jede-star",
          "description": "jeder*jede → jeder/jede",
