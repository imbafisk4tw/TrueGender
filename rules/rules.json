{
  "meta": {
    "version": "2.1.0",
    "description": "Ersetzungsregeln für gegenderte Schreibweisen → korrektes Deutsch",
    "modes": {
      "b": "Beide Formen",
      "m": "Männliche Form",
      "w": "Weibliche Form",
      "n": "Geschlechtsneutral",
      "c": "Custom-Profil"
    }
  },
  "rules": {
    "genderStar": {
      "description": "Genderstern, Doppelpunkt, Unterstrich — Pluralformen auf -innen",
      "enabled": true,
      "rules": [
        {
          "id": "plural-innen-standard",
          "description": "Wörter auf *innen/:innen/_innen (z.B. Kund*innen → Kunden/Kundinnen)",
          "example": "Kund:innen",
          "pattern": "\\b([A-ZÄÖÜ][a-zäöüß]+(?:er|el|en|ent|ant|ist|at|ekt|eur|ör|ling|ier|ar|oge|oph|ot|urg|ner|ler|zer|ger|ber|der|fer|ter|wer|mer|ner))[*:_]innen\\b",
          "replacement": { "b": "$1 und $1innen", "m": "$1", "w": "$1innen", "n": "$1" },
          "flags": "g"
        },
        {
          "id": "plural-innen-case-umlaut",
          "description": "Ärzt*innen → Ärzte/Ärztinnen",
          "example": "Ärzt:innen",
          "pattern": "\\b(Ärzt)[*:_]innen\\b",
          "replacement": { "b": "Ärzte und Ärztinnen", "m": "Ärzte", "w": "Ärztinnen", "n": "Ärzteschaft" },
          "flags": "g"
        },
        {
          "id": "plural-innen-aerzte-lc",
          "description": "ärzt*innen (lowercase)",
          "example": "ärzt:innen",
          "pattern": "\\b(ärzt)[*:_]innen\\b",
          "replacement": { "b": "ärzte und ärztinnen", "m": "ärzte", "w": "ärztinnen", "n": "ärzteschaft" },
          "flags": "g"
        },
        {
          "id": "plural-innen-anwaelte",
          "description": "Anwält*innen → Anwälte/Anwältinnen",
          "example": "Anwält:innen",
          "pattern": "\\b(Anwält)[*:_]innen\\b",
          "replacement": { "b": "Anwälte und Anwältinnen", "m": "Anwälte", "w": "Anwältinnen", "n": "Anwaltschaft" },
          "flags": "g"
        },
        {
          "id": "plural-innen-koechinnen",
          "description": "Köch*innen → Köche/Köchinnen",
          "example": "Köch:innen",
          "pattern": "\\b(Köch)[*:_]innen\\b",
          "replacement": { "b": "Köche und Köchinnen", "m": "Köche", "w": "Köchinnen", "n": "Kochpersonal" },
          "flags": "g"
        },
        {
          "id": "plural-innen-lowercase",
          "description": "Kleinschreibung: wörter auf *innen/:innen/_innen",
          "example": "lehrer:innen",
          "pattern": "\\b([a-zäöüß]+(?:er|el|en|ent|ant|ist|at|ekt|eur|ör|ling|ier|ar|oge|oph|ot|urg|ner|ler|zer|ger|ber|der|fer|ter|wer|mer|ner))[*:_]innen\\b",
          "replacement": { "b": "$1 und $1innen", "m": "$1", "w": "$1innen", "n": "$1" },
          "flags": "g"
        },
        {
          "id": "singular-in-no-e",
          "description": "Singular ohne -e: Lehrer*in → Lehrer/Lehrerin",
          "example": "Lehrer:in",
          "pattern": "\\b([A-ZÄÖÜ][a-zäöüß]*(?:er|ler|ner|ger|ber|der|fer|ter|wer|mer))[*:_]in\\b",
          "replacement": { "b": "$1 oder $1in", "m": "$1", "w": "$1in", "n": "$1" },
          "flags": "g"
        },
        {
          "id": "singular-in-standard",
          "description": "Singular: Kund*in/:in/_in → Kunde/Kundin",
          "example": "Kund:in",
          "pattern": "\\b([A-ZÄÖÜ][a-zäöüß]+(?:er|el|en|ent|ant|ist|at|ekt|eur|ör|ling|ier|ar|oge|oph|ot|urg|ner|ler|zer|ger|ber|der|fer|ter|wer|mer|ner))[*:_]in\\b",
          "replacement": { "b": "$1e oder $1in", "m": "$1e", "w": "$1in", "n": "$1e" },
          "flags": "g"
        },
        {
          "id": "singular-in-lowercase-no-e",
          "description": "Singular Kleinschreibung ohne -e: lehrer:in → lehrer/lehrerin",
          "example": "lehrer:in",
          "pattern": "\\b([a-zäöüß]+(?:er|ler|ner|ger|ber|der|fer|ter|wer|mer))[*:_]in\\b",
          "replacement": { "b": "$1 oder $1in", "m": "$1", "w": "$1in", "n": "$1" },
          "flags": "g"
        },
        {
          "id": "singular-in-lowercase",
          "description": "Singular Kleinschreibung",
          "example": "expert:in",
          "pattern": "\\b([a-zäöüß]+(?:er|el|en|ent|ant|ist|at|ekt|eur|ör|ling|ier|ar|oge|oph|ot|urg|ner|ler|zer|ger|ber|der|fer|ter|wer|mer|ner))[*:_]in\\b",
          "replacement": { "b": "$1e oder $1in", "m": "$1e", "w": "$1in", "n": "$1e" },
          "flags": "g"
        }
      ]
    },
    "binnenI": {
      "description": "Binnen-I Formen (MitarbeiterInnen, KollegInnen)",
      "enabled": true,
      "rules": [
        {
          "id": "binnen-i-plural",
          "description": "MitarbeiterInnen → Mitarbeiter/Mitarbeiterinnen",
          "example": "MitarbeiterInnen",
          "pattern": "\\b([A-ZÄÖÜ][a-zäöüß]+(?:er|el|en|ent|ant|ist|at|ekt|eur|ör|ling|ier|ar|oge|oph|ot|urg))Innen\\b",
          "replacement": { "b": "$1 und $1innen", "m": "$1", "w": "$1innen", "n": "$1" },
          "flags": "g"
        },
        {
          "id": "binnen-i-singular",
          "description": "MitarbeiterIn → Mitarbeiter/Mitarbeiterin",
          "example": "MitarbeiterIn",
          "pattern": "\\b([A-ZÄÖÜ][a-zäöüß]+(?:er|el|en|ent|ant|ist|at|ekt|eur|ör|ling|ier|ar|oge|oph|ot|urg))In\\b",
          "replacement": { "b": "$1 oder $1in", "m": "$1", "w": "$1in", "n": "$1" },
          "flags": "g"
        }
      ]
    },
