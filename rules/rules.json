        },
        {
          "id": "lehrerinnen-und-lehrer",
          "description": "Lehrerinnen und Lehrer → Lehrer/Lehrerinnen",
          "example": "Lehrerinnen und Lehrer",
          "pattern": "\\bLehrerinnen und Lehrer\\b",
          "replacement": { "b": "Lehrer und Lehrerinnen", "m": "Lehrer", "w": "Lehrerinnen", "n": "Lehrkräfte" },
          "flags": "g"
        },
        {
          "id": "doppel-innen-und",
          "description": "Xinnen und X → X (m) oder Xinnen (w)",
          "example": "Partnerinnen und Partner",
          "pattern": "\\b([A-ZÄÖÜ][a-zäöüß]+(?:er|el|ent|ant|ist|at|ekt|eur|ör|ier|ar))innen und \\1\\b",
          "replacement": { "b": "$1 und $1innen", "m": "$1", "w": "$1innen", "n": "$1" },
          "flags": "g"
        },
        {
          "id": "doppel-und-innen",
          "description": "X und Xinnen → X (m) oder Xinnen (w)",
          "example": "Partner und Partnerinnen",
          "pattern": "\\b([A-ZÄÖÜ][a-zäöüß]+(?:er|el|ent|ant|ist|at|ekt|eur|ör|ier|ar)) und \\1innen\\b",
          "replacement": { "b": "$1 und $1innen", "m": "$1", "w": "$1innen", "n": "$1" },
          "flags": "g"
        },
        {
          "id": "doppel-er-sie",
          "description": "er oder sie / sie oder er → er/sie",
          "example": "er oder sie",
          "pattern": "\\b(er|sie) oder (sie|er)\\b",
          "replacement": { "b": "er oder sie", "m": "er", "w": "sie", "n": "die Person" },
          "flags": "gi"
        }
      ]
    },
